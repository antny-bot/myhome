# =========================================================================
# MyHome 시스템 환경 변수 설정 템플릿 (.env.example)
# =========================================================================

# [기본 웹/백엔드 설정]
# 포트 변경 팁: 다른 서비스와 포트가 충돌하는 경우, 이 값을 변경하면 됩니다.
# docker-compose.yml이 이 포트를 참조하여 호스트 노출 포트(${PORT:-4174}:4174)로 연동합니다.
PORT=4174

# 수집 스케줄러 및 룰 매칭 주기 (초 단위, 기본 300초 = 5분)
CHECK_INTERVAL_SECONDS=300

# [Telegram 텔레그램 알림 설정 - 선택]
# 룰 매칭 시 알림 메시지를 수신하기 위한 텔레그램 봇 토큰 및 수신 대상 채팅방 ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# [주소 검색 API 설정 - 둘 중 하나만 입력해도 무방]
# 1) 카카오 Local 주소 검색 REST API 키 (Kakao Developers 발급)
#    - 지역명(예: 강남구) 검색 시 5자리 지역코드(LAWD_CD)로 매핑하는 용도입니다.
KAKAO_REST_API_KEY=

# 2) 행정안전부 도로명주소 오픈 API 승인키 (business.juso.go.kr 발급)
#    - 카카오 API 키가 이미 설정되어 있는 경우, 이 키는 빈칸으로 두셔도 정상 동작합니다.
JUSO_CONFM_KEY=

# [국토교통부 실거래가 오픈 API 설정 - 필수]
# 공공데이터포털(data.go.kr)의 "국토교통부 아파트매매 실거래 상세 자료 API" 일반 인증키입니다.
# 실제 아파트 실거래 데이터(금액, 면적, 층 등)를 긁어오기 위한 필수 키이며 대체 불가합니다.
DATA_GO_KR_API_KEY=

# SQLite DB 적재 활성화 여부 (로컬 분석 및 하이브리드 캐싱을 위해 true 설정 권장)
GRAPH_DB_ENABLED=true

# [카카오맵 API 설정 - 지도 렌더링용]
# 프론트엔드 React 화면에서 카카오 지도를 로드하고 렌더링할 때 사용하는 키입니다.
KAKAO_JAVASCRIPT_KEY=
KAKAO_NATIVE_APP_KEY=
VITE_KAKAO_MAP_API_KEY=

# [Google OAuth 2.0 로그인 및 보안 설정 - 필수]
# 구글 로그인 연동을 위한 ID 및 비밀키
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 구글 OAuth 리디렉션 콜백 URL
# - 로컬 개발 환경: http://localhost:4174/api/auth/google/callback
# - 실서버 환경: https://myhome.deboox.com/api/auth/google/callback
#   (※ 주의: Google Cloud Console의 "승인된 리디렉션 URI"에도 완전히 동일하게 등록되어야 합니다.)
GOOGLE_REDIRECT_URI=http://localhost:4174/api/auth/google/callback
# 대시보드 접근을 허용할 구글 이메일 목록 (쉼표로 구분하여 기재, 빈칸일 시 로그인 불가)
ALLOWED_EMAILS=
# 대시보드 관리자 권한을 부여할 구글 이메일 목록 (ALLOWED_EMAILS에 속한 이메일 중 지정, 쉼표로 구분. 비어있을 시 첫 번째 이메일이 임시 관리자)
ADMIN_EMAILS=
