PORT=4174
CHECK_INTERVAL_SECONDS=300
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 카카오 Local 주소 검색용 REST API 키 (지역명 자동완성/범위 좁히기에 사용)
# 없으면 기존 MCP 단일 검색으로 동작합니다.
KAKAO_REST_API_KEY=

# 행정안전부 도로명주소 오픈 API 승인키 (business.juso.go.kr)
JUSO_CONFM_KEY=

# Neo4j Aura 그래프 DB (Phase 7 — 이력 적재)
# false로 설정하면 기존 JSON 저장소만 사용 (하위 호환)
GRAPH_DB_ENABLED=false
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Kakao Developers 플랫폼 추가 키
KAKAO_JAVASCRIPT_KEY=
KAKAO_NATIVE_APP_KEY=

# Vite 웹 프론트엔드에서 Kakao 지도 로드에 사용할 키
VITE_KAKAO_MAP_API_KEY=
