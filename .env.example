# =========================================================================
# MyHome 시스템 환경 변수 설정 템플릿 (.env.example)
# =========================================================================

# 1. 기본 웹/백엔드 설정
# - PORT: 다른 서비스와 포트 충돌 시 변경 가능 (docker-compose.yml 호스트 포트 자동 연동)
PORT=4174
# - CHECK_INTERVAL_SECONDS: 수집 스케줄러 및 알림 룰 매칭 주기 (초 단위, 기본 300초 = 5분)
CHECK_INTERVAL_SECONDS=300

# 2. 데이터베이스 설정 (SQLite)
# - GRAPH_DB_ENABLED: SQLite 실거래가 DB 적재 스위치 (하이브리드 캐싱 작동을 위해 true 권장)
GRAPH_DB_ENABLED=true

# 3. 국토교통부 실거래가 오픈 API 설정 (필수)
# - DATA_GO_KR_API_KEY: 공공데이터포털(data.go.kr) 발급 국토부 실거래 상세 조회 API 일반인증키 (대체 불가)
DATA_GO_KR_API_KEY=

# 4. 주소 검색 API 설정 (선택 - 둘 중 하나만 입력해도 무방)
# - KAKAO_REST_API_KEY: 카카오 Local API REST 키 (시군구 5자리 코드 LAWD_CD 매핑용)
KAKAO_REST_API_KEY=
# - JUSO_CONFM_KEY: 행정안전부 도로명주소 API 승인키 (카카오 키가 있으면 빈칸 가능)
JUSO_CONFM_KEY=

# 5. 카카오맵 API 설정 (지도 렌더링용)
# - 프론트엔드 React 웹 화면에서 카카오 지도를 로딩/사용하기 위한 키입니다.
KAKAO_JAVASCRIPT_KEY=
KAKAO_NATIVE_APP_KEY=
VITE_KAKAO_MAP_API_KEY=

# 6. Telegram 텔레그램 알림 설정 (선택)
# - TELEGRAM_BOT_TOKEN: 텔레그램 봇 토큰 (bot 으로 시작)
TELEGRAM_BOT_TOKEN=
# - TELEGRAM_CHAT_ID: 알림을 수신할 대화방/채널 ID
TELEGRAM_CHAT_ID=

# 7. Google OAuth 2.0 로그인 및 보안 설정 (필수)
# - 구글 로그인 연동을 위해 발급받은 클라이언트 ID 및 보안 비밀번호
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# - GOOGLE_REDIRECT_URI: 구글 OAuth 로그인 후 복귀할 콜백 URL
#   (※ 주의: Google Cloud Console의 "승인된 리디렉션 URI"에도 완전히 동일하게 등록되어야 합니다.)
#   * 로컬 개발 시: http://localhost:4174/api/auth/google/callback
#   * 실서버 배포 시: https://myhome.deboox.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:4174/api/auth/google/callback

# 8. 대시보드 접근 권한 이메일 목록 (보안 필수)
# - ALLOWED_EMAILS: 대시보드 접근 허용 구글 이메일 주소 목록 (쉼표 구분, 공란 시 전면 거부)
ALLOWED_EMAILS=
# - ADMIN_EMAILS: 대시보드 관리자 권한 부여 구글 이메일 주소 목록 (ALLOWED_EMAILS 중 기입)
ADMIN_EMAILS=
