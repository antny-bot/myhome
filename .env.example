PORT=4174
CHECK_INTERVAL_SECONDS=300
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 카카오 Local 주소 검색용 REST API 키 (지역명 자동완성/범위 좁히기에 사용)
# 없으면 기존 MCP 단일 검색으로 동작합니다.
KAKAO_REST_API_KEY=

# 행정안전부 도로명주소 오픈 API 승인키 (business.juso.go.kr)
JUSO_CONFM_KEY=


# Kakao Developers 플랫폼 추가 키
KAKAO_JAVASCRIPT_KEY=
KAKAO_NATIVE_APP_KEY=

# Vite 웹 프론트엔드에서 Kakao 지도 로드에 사용할 키
VITE_KAKAO_MAP_API_KEY=

# Google OAuth 2.0 로그인 설정
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4174/api/auth/google/callback
# 대시보드 접근을 허용할 구글 이메일 목록 (쉼표로 구분하여 기재, 빈칸일 시 로그인 불가)
ALLOWED_EMAILS=
# 대시보드 관리자 권한을 부여할 구글 이메일 목록 (ALLOWED_EMAILS에 속한 이메일 중 지정, 쉼표로 구분. 비어있을 시 첫 번째 이메일이 임시 관리자)
ADMIN_EMAILS=
