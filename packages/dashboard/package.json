{
  "name": "@myhome/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.json && vite build && tsc -p tsconfig.node.json",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.node.json",
    "start:server": "tsx server/index.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@myhome/collector": "*",
    "@myhome/shared": "*",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "nanoid": "^5.1.6",
    "pretendard": "^1.3.9",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.1",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.21.0",
    "vite": "^7.2.7",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
